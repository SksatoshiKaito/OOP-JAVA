class BankAccount {
    private double balance; 

    public BankAccount(double initialBalance) {
        if (initialBalance > 0) {
            this.balance = initialBalance;
        } else {
            this.balance = 0;
        }
    }

    public void deposit(double amt) {
        if (amt > 0) { 
            this.balance += amt;
            System.out.println("Successfully deposited: " + amt);
        } else {
            System.out.println("Invalid amount! Cannot deposit negative or zero.");
        }
    }

    public double getBalance() {
        return this.balance;
    }
}

public class Main {
    public static void main(String[] args) {
        BankAccount myAccount = new BankAccount(500);
        
        myAccount.deposit(200);
        myAccount.deposit(-50);

        System.out.println("Current account balance: " + myAccount.getBalance());
    }
}
